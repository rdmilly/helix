# Helix Cortex Environment Variables

# === API Configuration ===
HELIX_PORT=9050
HELIX_HOST=0.0.0.0
HELIX_ALLOWED_ORIGINS=*

# === Database ===
HELIX_MAX_QUEUE_DEPTH=1000
HELIX_MAX_RETRY_ATTEMPTS=3

# === ChromaDB ===
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# === Anthropic API ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === MinIO ===
MINIO_ENDPOINT=minio.millyweb.com
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=helix

# === Security ===
HELIX_ENCRYPTION_KEY=your_encryption_key_from_infisical
